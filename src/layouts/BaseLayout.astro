---
import "../styles/global.css";
import IntroScene from "../components/IntroScene.astro";
import BrandClient from "../components/BrandClient.tsx";

interface Props {
  title?: string;
  description?: string;
  hideHeaderIntro?: boolean;
  showIntro?: boolean;
  noindex?: boolean;
  ogImage?: string;
  ogTitle?: string;
  ogDescription?: string;
  adminMode?: boolean;
}

const {
  title = "Yuly Alejandra Polanía Molano - Diseñadora Visual de Contenido",
  description = "Portafolio de Yuly Alejandra Polanía Molano - Estratega de Contenido y Diseñadora Visual",
  hideHeaderIntro = false,
  showIntro = false,
  noindex = false,
  ogImage = "https://placehold.co/1200x630/1E1B4A/FFFFFF?text=Yuly+Polania",
  ogTitle,
  ogDescription = description,
  adminMode = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={ogTitle ?? title} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <script is:inline>
      (function () {
        try {
          var name = localStorage.getItem("brand:name");
          if (!name) return;
          function apply() {
            var els = document.querySelectorAll("[data-brand-name],[data-brand-name-full]");
            els.forEach(function (el) { el.textContent = name; });
          }
          document.addEventListener("DOMContentLoaded", apply, { once: true });
          if (document.readyState !== "loading") apply();
          window.__BRAND_READY__ = true;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Saltar al contenido</a>
    {showIntro && <IntroScene />}
    
    <!-- Scroll progress bar -->
    <div class="scroll-progress" aria-hidden="true">
      <div class="scroll-progress-bar"></div>
    </div>

    <!-- Back to top -->
    <button id="back-to-top" class="back-to-top" aria-label="Volver arriba">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>

    {adminMode ? (
      <header id="admin-layout-header" class="site-header admin-layout-header">
        <div class="header-inner">
          <div class="brand">
            <a href="/" class="logo"><span data-brand-name>Yuly Polanía</span><span class="accent">.</span></a>
            <span class="brand-tagline">Panel admin</span>
          </div>
          <div class="admin-layout-header-actions">
            <a href="/" class="admin-layout-back" target="_blank" rel="noopener noreferrer" title="Abrir sitio público en una nueva pestaña">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                <polyline points="15 3 21 3 21 9"/>
                <line x1="10" y1="14" x2="21" y2="3"/>
              </svg>
              <span>Ir al sitio público</span>
            </a>
            <span id="admin-layout-header-slot"></span>
          </div>
        </div>
      </header>
    ) : (
      <header class:list={["site-header", (showIntro || hideHeaderIntro) && "header-intro-hidden"]}>
        <div class="header-inner">
          <div class="brand">
            <a href="/" class="logo"><span data-brand-name>Yuly Polanía</span><span class="accent">.</span></a>
            <span class="brand-tagline">Estratega de Contenido · Diseñadora Visual</span>
          </div>
          <button
            class="nav-toggle"
            aria-label="Abrir menú de navegación"
            aria-expanded="false"
            aria-controls="primary-nav"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>
          <nav id="primary-nav" class="nav" aria-label="Principal">
            <a href="/#trabajo" class="nav-link" data-nav="trabajo">
              Trabajo
              <span class="nav-underline"></span>
            </a>
            <a href="/#sobre-mi" class="nav-link" data-nav="sobre-mi">
              Sobre mí
              <span class="nav-underline"></span>
            </a>
            <a href="/#trayectoria" class="nav-link" data-nav="trayectoria">
              Trayectoria
              <span class="nav-underline"></span>
            </a>
            <a href="/#contacto" class="nav-link" data-nav="contacto">
              Contacto
              <span class="nav-underline"></span>
            </a>
          </nav>
        </div>
      </header>
    )}

    <main id="main">
      <slot />
    </main>

    <BrandClient client:load />

    <footer class="site-footer">
      <p>© {new Date().getFullYear()} <span data-brand-name-full>Yuly Polanía</span>. Todos los derechos reservados.</p>
    </footer>

    <script>
      import { animate, scroll } from "motion";

      // Scroll progress bar
      const progressBar = document.querySelector('.scroll-progress-bar');
      if (progressBar) {
        scroll(
          (progress) => {
            progressBar.style.width = `${progress * 100}%`;
          },
          { target: document.documentElement }
        );
      }

      // Nav link active state on scroll
      const navLinks = document.querySelectorAll('.nav-link[data-nav]');
      const sections = Array.from(navLinks).map(link => 
        document.getElementById(link.dataset.nav)
      ).filter(Boolean);

      if (sections.length > 0) {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              const id = entry.target.id;
              navLinks.forEach(link => {
                link.classList.toggle('active', link.dataset.nav === id);
              });
            }
          });
        }, { rootMargin: '-50% 0px -50% 0px', threshold: 0.1 });

        sections.forEach(section => observer.observe(section));
      }

      // IntersectionObserver for reveal animations (fallback for non-motion elements)
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });

      function bootReveal() {
        document.querySelectorAll('.reveal:not(.revealed)').forEach(el => {
          revealObserver.observe(el);
        });
      }
      bootReveal();
      document.addEventListener('astro:page-load', bootReveal);

      // Reveal elements injected after load (e.g. client:only React islands like
      // ProjectDetailClient) so they aren't stuck at opacity: 0.
      const revealWatcher = new MutationObserver((mutations) => {
        for (const m of mutations) {
          m.addedNodes.forEach((node) => {
            if (node.nodeType !== 1) return;
            if (node.classList?.contains('reveal') && !node.classList.contains('revealed')) {
              revealObserver.observe(node);
            }
            node.querySelectorAll?.('.reveal:not(.revealed)').forEach((el) => revealObserver.observe(el));
          });
        }
      });
      revealWatcher.observe(document.body, { childList: true, subtree: true });

      // Smooth scroll for same-page anchor links only
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        const targetId = anchor.getAttribute('href');
        if (!targetId || targetId === '#') return;

        const isAbsoluteNavLink = targetId.startsWith('/#');
        const target = document.querySelector(targetId.replace(/^\/#/, '#') || targetId);

        if (!isAbsoluteNavLink && target) {
          anchor.addEventListener('click', function(e) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.pushState(null, '', targetId);
          });
        }
      });

      // Enhanced button micro-interactions
      document.querySelectorAll('.btn-primary, .btn-secondary').forEach(btn => {
        btn.addEventListener('mousedown', () => {
          animate(btn, { scale: 0.98 }, { duration: 0.1 });
        });
        btn.addEventListener('mouseup', () => {
          animate(btn, { scale: 1 }, { duration: 0.1, ease: 'easeOut' });
        });
        btn.addEventListener('mouseleave', () => {
          animate(btn, { scale: 1 }, { duration: 0.2, ease: 'easeOut' });
        });
      });

      // Back to top
      const backToTop = document.getElementById('back-to-top');
      if (backToTop) {
        backToTop.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        window.addEventListener('scroll', () => {
          if (window.scrollY > 600) {
            backToTop.classList.add('visible');
          } else {
            backToTop.classList.remove('visible');
          }
        });
      }

      // Contact link hover animation
      document.querySelectorAll('.contact-link').forEach(link => {
        link.addEventListener('mouseenter', () => {
          animate(link, { x: 8 }, { duration: 0.3, ease: [0.16, 1, 0.3, 1] });
        });
        link.addEventListener('mouseleave', () => {
          animate(link, { x: 0 }, { duration: 0.4, ease: [0.16, 1, 0.3, 1] });
        });
      });

      // Mobile navigation toggle
      const navToggle = document.querySelector('.nav-toggle');
      const primaryNav = document.getElementById('primary-nav');
      if (navToggle && primaryNav) {
        const closeNav = () => {
          primaryNav.classList.remove('open');
          navToggle.setAttribute('aria-expanded', 'false');
        };

        navToggle.addEventListener('click', () => {
          const isOpen = primaryNav.classList.toggle('open');
          navToggle.setAttribute('aria-expanded', String(isOpen));
        });

        primaryNav.querySelectorAll('.nav-link').forEach(link => {
          link.addEventListener('click', closeNav);
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') closeNav();
        });

        window.addEventListener('resize', () => {
          if (window.innerWidth > 768) closeNav();
        });
      }

      if ('scrollRestoration' in history) {
        history.scrollRestoration = 'auto';
      }
      if (!window.location.hash) {
        window.scrollTo(0, 0);
      }
      document.addEventListener('astro:page-load', () => {
        if (!window.location.hash) {
          window.scrollTo(0, 0);
        }
        const header = document.querySelector('.site-header.header-intro-hidden');
        if (header && window.location.hash) {
          header.classList.add('header-visible');
          header.classList.remove('header-intro-hidden');
        }
      });
    </script>
  </body>
</html>
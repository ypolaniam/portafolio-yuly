---
import BaseLayout from "../layouts/BaseLayout.astro";
import IntroScene from "../components/IntroScene.astro";
import Hero from "../components/Hero.astro";
import ProjectsGrid from "../components/ProjectsGrid.astro";
import About from "../components/About.astro";
import Timeline from "../components/Timeline.astro";
import Contact from "../components/Contact.astro";
import { projects } from "../data/projects.js";
---

<BaseLayout title="PolaMola — Diseñadora UI/UX" description="Portafolio de PolaMola — Diseñadora UI/UX especializada en productos digitales, sistemas de diseño y branding." hideHeaderIntro={true} showIntro={true}>
  <Hero />
  <ProjectsGrid projects={projects} />
  <About />
  <Timeline />
  <Contact />
</BaseLayout>
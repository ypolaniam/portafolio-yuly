---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectDetailClient from "../../components/ProjectDetailClient.tsx";
import { initialProjects } from "../../data/projects";
import type { Project } from "../../types/project";

export async function getStaticPaths() {
  return initialProjects.map((project) => ({
    params: { slug: project.slug },
    props: { initialProject: project },
  }));
}

const { slug } = Astro.params;
const { initialProject } = Astro.props;
---

<BaseLayout
  title={`${initialProject?.title || "Proyecto"} — Yuly Polanía Molano`}
  description={initialProject?.description || "Detalle del proyecto"}
  ogImage={initialProject?.image || "https://placehold.co/1200x630/1E1B4A/FFFFFF?text=Proyecto"}
>
  <ProjectDetailClient client:only="react" initialSlug={slug} initialProject={initialProject} />
</BaseLayout>

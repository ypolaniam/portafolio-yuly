---
const { delay = 0, class: className = '', children } = Astro.props;
---
<div class="motion-reveal" data-delay={delay} class:list={[className]}>
  <slot />
</div>

<script type="module">
  import { animate, inView } from "motion";

  const elements = document.querySelectorAll('.motion-reveal:not(.animated)');
  
  elements.forEach(el => {
    const delay = parseInt(el.dataset.delay || '0', 10);
    
    inView(el, () => {
      el.classList.add('animated');
      animate(el, 
        { opacity: [0, 1], y: [30, 0] }, 
        { duration: 0.5, delay: delay / 1000, ease: [0.16, 1, 0.3, 1] }
      );
    }, { once: true, margin: "-50px" });
  });
</script>

<style>
  .motion-reveal {
    opacity: 0;
  }
  
  .motion-reveal.animated {
    opacity: 1;
  }
</style>
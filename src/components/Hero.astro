---
import MotionWrapper from "./MotionWrapper.astro";
---

<section class="hero" aria-label="Presentación">
  <div class="hero-inner">
    <MotionWrapper delay={100} stagger={0.12}>
      <p class="hero-overline">Estratega de Contenido · Diseñadora Visual</p>
      
      <h1 class="hero-title">
        <span class="gradient-text">Yuly Alejandra</span>
        <br>
        <span class="gradient-text">Polania Molano</span>
      </h1>
      
      <p class="hero-subtitle">
        Diseñadora con curiosidad inquieta y visión transformadora. Combino diseño gráfico e industrial 
        para crear experiencias visuales y narrativas que conectan con lo intuitivo. 
        Creo en el diseño con propósito, evolución constante e impacto de los pequeños detalles.
      </p>
      
      <div class="hero-actions">
        <a href="#trabajo" class="btn-primary magnetic">Ver trabajo</a>
        <a href="#contacto" class="btn-secondary magnetic">Contactar</a>
      </div>
      
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-number" data-count="4">0</span>
          <span class="stat-label">Años experiencia</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-count="15">0</span>
          <span class="stat-label">Proyectos</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-count="2271">0</span>
          <span class="stat-label">% Crecimiento orgánico</span>
        </div>
      </div>
    </MotionWrapper>
    
    <div class="hero-visual" data-parallax>
      <div class="hero-photo">
        <img src="https://placehold.co/600x800/8B5CF6/FFFFFF?text=Yuly" alt="Yuly Alejandra Polanía Molano" loading="eager" />
      </div>
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="grid-overlay"></div>
    </div>
  </div>
  
  <div class="scroll-indicator" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>
</section>

<script type="module">
  import { animate, scroll, inView } from "motion";
  
  // Text reveal animation (word by word)
  const revealTexts = document.querySelectorAll('.reveal-text[data-reveal="word"]');
  revealTexts.forEach((el, i) => {
    const text = el.textContent;
    const words = text.trim().split(/\s+/);
    el.innerHTML = words.map((word, wi) => 
      `<span class="reveal-word" style="--i:${wi}">${word}</span>`
    ).join(' ');
    
    const wordEls = el.querySelectorAll('.reveal-word');
    wordEls.forEach((word, wi) => {
      word.style.opacity = '0';
      word.style.transform = 'translateY(1.2em)';
      word.style.display = 'inline-block';
      word.style.willChange = 'opacity, transform';
    });
    
    inView(el, () => {
      animate(wordEls, 
        { opacity: [0, 1], y: ['1.2em', 0] },
        { duration: 0.35, ease: [0.16, 1, 0.3, 1], delay: (i, index) => index * 0.02 }
      );
    }, { once: true, margin: "-50px" });
  });
  
  // Counter animation for stats
  const statNumbers = document.querySelectorAll('.stat-number[data-count]');
  statNumbers.forEach(el => {
    const target = parseInt(el.dataset.count);
    inView(el, () => {
      animate(0, target, {
        duration: 1.5,
        ease: "easeOut",
        onUpdate: (v) => el.textContent = Math.round(v).toLocaleString()
      });
    }, { once: true, margin: "-100px" });
  });
  
  // Floating blobs animation
  const shapes = document.querySelectorAll('.blob');
  shapes.forEach((shape, i) => {
    animate(shape, 
      { 
        y: [0, -30, 0], 
        x: [0, 20, 0],
        rotate: [0, 8, 0],
        scale: [1, 1.05, 1]
      }, 
      { 
        duration: 8 + i * 3, 
        repeat: Infinity, 
        ease: "easeInOut",
        delay: i * 0.7
      }
    );
  });
  
  // Orb animations
  const orbs = document.querySelectorAll('.orb');
  orbs.forEach((orb, i) => {
    animate(orb, 
      { 
        scale: [1, 1.3, 1],
        opacity: [0.15, 0.3, 0.15],
        borderRadius: ['50%', '30% 70% 70% 30% / 30% 30% 70% 70%', '50%']
      }, 
      { 
        duration: 10 + i * 4, 
        repeat: Infinity, 
        ease: "easeInOut",
        delay: i * 1.5
      }
    );
  });
  
  // Parallax on scroll
  const hero = document.querySelector('.hero');
  const visual = document.querySelector('.hero-visual');
  const grid = document.querySelector('.grid-overlay');
  const content = document.querySelector('.hero-content');
  
  if (hero && visual) {
    scroll(
      (progress) => {
        const y = progress * 150;
        const opacity = 1 - progress * 0.5;
        visual.style.transform = `translateY(${y}px)`;
        visual.style.opacity = opacity;
        
        if (content) {
          content.style.transform = `translateY(${progress * -30}px)`;
          content.style.opacity = 1 - progress * 0.3;
        }
      },
      { target: hero, offset: ["start start", "end start"] }
    );
  }
  
  if (grid) {
    scroll(
      (progress) => {
        grid.style.transform = `translateY(${progress * -100}px) rotate(${progress * 5}deg)`;
        grid.style.opacity = 0.03 - progress * 0.02;
      },
      { target: hero, offset: ["start start", "end start"] }
    );
  }
  
  // Scroll indicator animation
  const indicator = document.querySelector('.scroll-indicator');
  if (indicator) {
    animate(indicator, 
      { opacity: [0.4, 1, 0.4], y: [0, 10, 0] },
      { duration: 2, repeat: Infinity, ease: "easeInOut" }
    );
    
    scroll(
      (progress) => {
        indicator.style.opacity = 1 - progress * 3;
      },
      { target: hero, offset: ["start start", "100px start"] }
    );
  }
  
  // Mouse move parallax for shapes
  let mouseX = 0, mouseY = 0;
  document.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX / window.innerWidth - 0.5) * 2;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
  });
  
  function updateMouseParallax() {
    shapes.forEach((shape, i) => {
      const factor = (i + 1) * 15;
      const x = mouseX * factor;
      const y = mouseY * factor;
      shape.style.transform = `translate(${x}px, ${y}px)`;
    });
    
    orbs.forEach((orb, i) => {
      const factor = (i + 1) * 30;
      const x = mouseX * factor;
      const y = mouseY * factor;
      orb.style.transform = `translate(${x}px, ${y}px)`;
    });
    
    requestAnimationFrame(updateMouseParallax);
  }
  updateMouseParallax();
  
  // Magnetic buttons
  document.querySelectorAll('.magnetic').forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
    });
    
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = 'translate(0, 0)';
      btn.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
    });
  });
  
  // Reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    shapes.forEach(s => s.style.animation = 'none');
    orbs.forEach(o => o.style.animation = 'none');
  }

  // Hero photo float animation
  const photo = document.querySelector('.hero-photo');
  if (photo) {
    animate(photo, 
      { y: [0, -10, 0], rotate: [0, 0.5, 0] },
      { duration: 6, repeat: Infinity, ease: "easeInOut" }
    );
  }
</script>

<style>
  .hero-photo {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 3/4;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    margin-left: auto;
    will-change: transform;
  }

  .hero-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-photo::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(139,92,246,0.15) 0%, rgba(59,130,246,0.1) 100%);
    mix-blend-mode: overlay;
    pointer-events: none;
  }
</style>
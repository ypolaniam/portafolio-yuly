---
import MotionWrapper from "./MotionWrapper.astro";
---

<section class="hero hero-loading" aria-label="Presentación">
  <div class="hero-visual">
    <div class="hero-photo">
      <img src="https://placehold.co/600x800/8B5CF6/FFFFFF?text=Yuly" alt="Yuly Alejandra Polanía Molano" loading="eager" />
    </div>
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
    <div class="blob blob-3"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="grid-overlay"></div>
  </div>

  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-overline reveal-item">Estratega de Contenido · Diseñadora Visual</p>
      
      <h1 class="hero-title reveal-item">
        <span class="gradient-text">Yuly Alejandra</span>
        <br>
        <span class="gradient-text">Polania Molano</span>
      </h1>
      
      <p class="hero-subtitle reveal-item">
        Diseñadora con curiosidad inquieta y visión transformadora. Combino diseño gráfico e industrial 
        para crear experiencias visuales y narrativas que conectan con lo intuitivo. 
        Creo en el diseño con propósito, evolución constante e impacto de los pequeños detalles.
      </p>
      
      <div class="hero-actions reveal-item">
        <a href="#trabajo" class="btn-primary magnetic">Ver trabajo</a>
        <a href="#contacto" class="btn-secondary magnetic">Contactar</a>
      </div>
      
      <div class="hero-stats reveal-item">
        <div class="stat">
          <span class="stat-number" data-count="4">0</span>
          <span class="stat-label">Años experiencia</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-count="15">0</span>
          <span class="stat-label">Proyectos</span>
        </div>
        <div class="stat">
          <span class="stat-number" data-count="2271">0</span>
          <span class="stat-label">% Crecimiento orgánico</span>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-indicator" aria-hidden="true">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <path d="M12 5v14M19 12l-7 7-7-7"/>
    </svg>
  </div>
</section>

<script type="module">
  import { animate, scroll, inView } from "motion";
  
  // Text reveal animation (word by word)
  const revealTexts = document.querySelectorAll('.reveal-text[data-reveal="word"]');
  revealTexts.forEach((el, i) => {
    const text = el.textContent;
    const words = text.trim().split(/\s+/);
    el.innerHTML = words.map((word, wi) => 
      `<span class="reveal-word" style="--i:${wi}">${word}</span>`
    ).join(' ');
    
    const wordEls = el.querySelectorAll('.reveal-word');
    wordEls.forEach((word, wi) => {
      word.style.opacity = '0';
      word.style.transform = 'translateY(1.2em)';
      word.style.display = 'inline-block';
      word.style.willChange = 'opacity, transform';
    });
    
    inView(el, () => {
      animate(wordEls, 
        { opacity: [0, 1], y: ['1.2em', 0] },
        { duration: 0.35, ease: [0.16, 1, 0.3, 1], delay: (i, index) => index * 0.02 }
      );
    }, { once: true, margin: "-50px" });
  });
  
  // Counter animation for stats
  const statNumbers = document.querySelectorAll('.stat-number[data-count]');
  statNumbers.forEach(el => {
    const target = parseInt(el.dataset.count);
    inView(el, () => {
      animate(0, target, {
        duration: 1.5,
        ease: "easeOut",
        onUpdate: (v) => el.textContent = Math.round(v).toLocaleString()
      });
    }, { once: true, margin: "-100px" });
  });
  
  // Floating blobs animation
  const shapes = document.querySelectorAll('.blob');
  shapes.forEach((shape, i) => {
    animate(shape, 
      { 
        y: [0, -30, 0], 
        x: [0, 20, 0],
        rotate: [0, 8, 0],
        scale: [1, 1.05, 1]
      }, 
      { 
        duration: 8 + i * 3, 
        repeat: Infinity, 
        ease: "easeInOut",
        delay: i * 0.7
      }
    );
  });
  
  // Orb animations
  const orbs = document.querySelectorAll('.orb');
  orbs.forEach((orb, i) => {
    animate(orb, 
      { 
        scale: [1, 1.3, 1],
        opacity: [0.15, 0.3, 0.15],
        borderRadius: ['50%', '30% 70% 70% 30% / 30% 30% 70% 70%', '50%']
      }, 
      { 
        duration: 10 + i * 4, 
        repeat: Infinity, 
        ease: "easeInOut",
        delay: i * 1.5
      }
    );
  });
  
  // Parallax on scroll
  const hero = document.querySelector('.hero');
  const visual = document.querySelector('.hero-visual');
  const grid = document.querySelector('.grid-overlay');
  const content = document.querySelector('.hero-inner');
  
  if (hero && visual) {
    scroll(
      (progress) => {
        const y = progress * 150;
        const opacity = 1 - progress * 0.5;
        visual.style.transform = `translateY(${y}px)`;
        visual.style.opacity = opacity;
        
        if (content) {
          content.style.transform = `translateY(${progress * -30}px)`;
          content.style.opacity = 1 - progress * 0.3;
        }
      },
      { target: hero, offset: ["start start", "end start"] }
    );
  }
  
  if (grid) {
    scroll(
      (progress) => {
        grid.style.transform = `translateY(${progress * -100}px) rotate(${progress * 5}deg)`;
        grid.style.opacity = 0.03 - progress * 0.02;
      },
      { target: hero, offset: ["start start", "end start"] }
    );
  }
  
  // Scroll indicator animation
  const indicator = document.querySelector('.scroll-indicator');
  if (indicator) {
    animate(indicator, 
      { opacity: [0.4, 1, 0.4], y: [0, 10, 0] },
      { duration: 2, repeat: Infinity, ease: "easeInOut" }
    );
    
    scroll(
      (progress) => {
        indicator.style.opacity = 1 - progress * 3;
      },
      { target: hero, offset: ["start start", "100px start"] }
    );
  }
  
  // Magnetic buttons
  document.querySelectorAll('.magnetic').forEach(btn => {
    btn.addEventListener('mousemove', (e) => {
      const rect = btn.getBoundingClientRect();
      const x = e.clientX - rect.left - rect.width / 2;
      const y = e.clientY - rect.top - rect.height / 2;
      btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
    });
    
    btn.addEventListener('mouseleave', () => {
      btn.style.transform = 'translate(0, 0)';
      btn.style.transition = 'transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
    });
  });

  // Intro reveal: staging hero after intro scene
  const waitIntro = setInterval(() => {
    const intro = document.querySelector('.intro-scene');
    if (!intro) {
      clearInterval(waitIntro);
      const heroEl = document.querySelector('.hero');
      if (heroEl) heroEl.classList.add('hero-visible');

      const revealItems = document.querySelectorAll('.reveal-item');
      const photo = document.querySelector('.hero-photo');
      const blobs = document.querySelectorAll('.blob');
      const orbs = document.querySelectorAll('.orb');
      const grid = document.querySelector('.grid-overlay');
      const indicator = document.querySelector('.scroll-indicator');
      const header = document.querySelector('.site-header');
      const logo = document.querySelector('.logo');
      const navLinks = document.querySelectorAll('.nav-link');

      requestAnimationFrame(() => {
        if (photo) {
          animate(photo, { opacity: [0, 1], rotateY: ['-15deg', '0deg'], x: [60, 0], scale: [0.9, 1] }, { duration: 1.3, ease: [0.16, 1, 0.3, 1] });
        }

        revealItems.forEach((el, i) => {
          animate(el, { opacity: [0, 1], y: [30, 0] }, { duration: 0.6, ease: [0.16, 1, 0.3, 1], delay: 0.12 + i * 0.07 });
        });

        blobs.forEach((blob, i) => {
          blob.style.opacity = '0';
          animate(blob, { opacity: [0, 0.18], scale: [0.5, 1], y: [50, 0] }, { duration: 1.7, ease: [0.16, 1, 0.3, 1], delay: 0.25 + i * 0.1 });
        });

        orbs.forEach((orb, i) => {
          orb.style.opacity = '0';
          animate(orb, { opacity: [0, 0.18], scale: [0.6, 1], y: [-40, 0] }, { duration: 1.8, ease: [0.16, 1, 0.3, 1], delay: 0.35 + i * 0.13 });
        });

        if (grid) {
          grid.style.opacity = '0';
          animate(grid, { opacity: [0, 1], rotate: [4, 0] }, { duration: 1.5, ease: [0.16, 1, 0.3, 1], delay: 0.45 });
        }

        if (indicator) {
          indicator.style.opacity = '0';
          animate(indicator, { opacity: [0, 1], y: [15, 0] }, { duration: 0.7, ease: [0.16, 1, 0.3, 1], delay: 1.1 });
        }

        // Header reveal: looks like Yuly Polania continues into the navbar
        if (header) {
          header.classList.add('header-visible');
          if (logo) {
            logo.style.opacity = '0';
            logo.style.transform = 'translateY(-10px)';
            logo.style.filter = 'blur(6px)';
            animate(logo,
              { opacity: [0, 1], y: [-10, 0], filter: ['blur(6px)', 'blur(0px)'] },
              { duration: 0.9, ease: [0.16, 1, 0.3, 1], delay: 0.4 }
            );
          }
          navLinks.forEach((link, i) => {
            link.style.opacity = '0';
            link.style.transform = 'translateY(-8px)';
            animate(link,
              { opacity: [0, 1], y: [-8, 0] },
              { duration: 0.7, ease: [0.16, 1, 0.3, 1], delay: 0.55 + i * 0.07 }
            );
          });
        }
      });
    }
  }, 120);
  
  // Reduced motion
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('.mesh-blob, .glass-panel').forEach(el => {
      el.style.animation = 'none';
    });
  }
</script>
